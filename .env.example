PORT=3000

# Fallback admin login when Supabase is not configured
ADMIN_USERNAME=나건후
ADMIN_PASSWORD=ngh-admin-1234
# ADMIN_PASSWORD_HASH=replace_with_hash_from_npm_run_hash_password

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.6-luna

# Supabase server connection
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_or_service_role_key

# Local SQLite fallback stats path when Supabase is not configured
DATA_DB_PATH=./data/word-stats.db

ADMIN_SESSION_DURATION_MS=43200000
ADMIN_LOGIN_WINDOW_MS=900000
ADMIN_LOGIN_BLOCK_MS=900000
ADMIN_MAX_LOGIN_ATTEMPTS=5
